# JWT signing secret (change to a random 256-bit value)
JWT_SECRET=changeme

# SQLite database URL
DATABASE_URL=sqlite+aiosqlite:///./data/db/sprout.db

# Directory for photo storage
PHOTO_STORAGE_PATH=./data/photos

# Service token expiry in days (for CLI-generated long-lived tokens)
JWT_SERVICE_EXPIRY_DAYS=365
