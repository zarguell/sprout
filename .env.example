# Sprout — Plant Care Tracker

# JWT secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=changeme

# Optional: override service token expiry (default 365 days)
# JWT_SERVICE_EXPIRY_DAYS=365

# Optional: override database URL (default: sqlite+aiosqlite:///./data/db/sprout.db)
# DATABASE_URL=sqlite+aiosqlite:///./data/db/sprout.db
